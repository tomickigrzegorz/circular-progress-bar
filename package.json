{
  "name": "@tomickigrzegorz/circular-progress-bar",
  "version": "1.4.0",
  "type": "module",
  "description": "A circular progress bar in svg",
  "main": "dist/circularProgressBar.js",
  "module": "dist/circularProgressBar.esm.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/circularProgressBar.esm.js",
      "require": "./dist/circularProgressBar.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "watch": "rollup -c -w --sourcemap --bundleConfigAsCjs",
    "build": "rollup -c --environment PRODUCTION --bundleConfigAsCjs",
    "typecheck": "tsc --noEmit",
    "prod": "yarn build && yarn lib:version",
    "lib:version": "node scripts/version.js",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write",
    "test": "playwright test"
  },
  "keywords": [
    "js",
    "svg",
    "circle",
    "animation",
    "progress",
    "progressbar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tomickigrzegorz/circular-progress-bar.git"
  },
  "bugs": {
    "url": "https://github.com/tomickigrzegorz/circular-progress-bar/issues"
  },
  "homepage": "https://github.com/tomickigrzegorz/circular-progress-bar#readme",
  "author": "Grzegorz Tomicki",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.23.9",
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/node": "^25.5.0",
    "core-js": "^3.36.0",
    "rollup": "^4.59.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^1.1.1",
    "rollup-plugin-terser": "^7.0.2",
    "typescript": "^5.7.2"
  }
}
